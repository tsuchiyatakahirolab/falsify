{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "FalsifyClaim",
  "type": "object",
  "required": [
    "id",
    "original_text",
    "normalized_claim",
    "claim_type",
    "testability",
    "evidence_requirements",
    "falsification_questions",
    "time_sensitive",
    "entities",
    "source_span"
  ],
  "properties": {
    "id": {
      "type": "string"
    },
    "original_text": {
      "type": "string",
      "minLength": 1
    },
    "normalized_claim": {
      "type": "string",
      "minLength": 1
    },
    "claim_type": {
      "enum": [
        "factual",
        "quantitative",
        "temporal",
        "comparative",
        "causal",
        "attribution_intent",
        "prediction",
        "historical_analogy",
        "interpretation",
        "normative"
      ]
    },
    "testability": {
      "enum": [
        "empirically_testable",
        "partially_testable",
        "not_empirically_falsifiable"
      ]
    },
    "evidence_requirements": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "falsification_questions": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string"
      }
    },
    "time_sensitive": {
      "type": "boolean"
    },
    "entities": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "source_span": {
      "type": [
        "object",
        "null"
      ],
      "properties": {
        "start": {
          "type": "integer",
          "minimum": 0
        },
        "end": {
          "type": "integer",
          "minimum": 0
        }
      },
      "required": [
        "start",
        "end"
      ],
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
