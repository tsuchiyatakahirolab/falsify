# Choose one live provider. The public zero-cost demo uses Gemini.
AI_PROVIDER=gemini

# Server-side only. Never expose either key to the browser.
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash-lite

# Optional GPT-5.6 path for self-hosters with OpenAI API billing or credits.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.6
