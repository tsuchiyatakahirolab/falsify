# Choose one live provider. The curated zero-cost demo needs no provider key.
AI_PROVIDER=gemini

# Server-side only. Never expose either key to the browser.
GEMINI_API_KEY=
GEMINI_MODEL=gemini-3.1-flash-lite

# Optional GPT-5.6 path for self-hosters with OpenAI API billing or credits.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.6
